# Copy this file to .env and fill in your values
# cp .env.example .env

# HuggingFace API token — get yours at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Neo4j connection — default values work if using the Docker setup from README
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
